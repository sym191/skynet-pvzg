root = "@PROJECT_SOURCE_DIR@/"
lua_root = "@SKPVZG_SHARED_LUA_ROOT@"
thread = 8
logger = "stdout"
start = "main"

luaservice = lua_root .. "/service/?.lua;" .. lua_root .. "/examples/?.lua"
lua_path = lua_root .. "/lualib/?.lua;" .. lua_root .. "/lualib/?/init.lua"
lua_cpath = "@SKPVZG_REFACTOR_OUTPUT_DIR@/luaclib/?.so"
cpath = "@SKPVZG_REFACTOR_OUTPUT_DIR@/cservice/?.so"
